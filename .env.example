# Copy to `.env` and fill in. NEVER commit your `.env`.

# === LLM providers (cascade) ===
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
OLLAMA_BASE_URL=
OLLAMA_MODEL=nemotron-3-nano:4b

# === ML model integrity ===
# Set to a long random string to enable HMAC-protected pickle loading.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Empty = plain SHA-256 (corruption-detection only, NOT tamper-proof).
MODEL_HMAC_SECRET=
